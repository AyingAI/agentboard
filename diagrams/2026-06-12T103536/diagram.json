      "id": "c_agent_dsl",
      "connector": {
        "from": "agent_reason",
        "to": "dsl_transform",
        "fromAnchor": "left",
        "toAnchor": "right",
        "lineShape": "curve",
        "lineColor": "#BBBFC4",
        "lineWidth": 2,
        "lineStyle": "dashed",
        "endArrow": "arrow"
      }
    },
    {
      "type": "connector",
      "id": "c_dsl_human",
      "connector": {
        "from": "dsl_transform",
        "to": "human_feedback",
        "fromAnchor": "left",
        "toAnchor": "right",
        "lineShape": "curve",
        "lineColor": "#BBBFC4",
        "lineWidth": 2,
        "lineStyle": "dashed",
        "endArrow": "arrow"
