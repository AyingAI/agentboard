      "connector": {
        "from": "dsl_schema",
        "to": "agent_understand",
        "fromAnchor": "right",
        "toAnchor": "left",
        "lineShape": "curve",
        "lineColor": "#BBBFC4",
        "lineWidth": 2,
        "endArrow": "arrow"
      }
    },
